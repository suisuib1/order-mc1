<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysBlogMapper">
    
    <resultMap type="SysBlog" id="SysBlogResult">
        <id     property="id"          column="id"           />
        <result property="title"       column="title"        />
        <result property="excerpt"     column="excerpt"      />
        <result property="content"     column="content"      />
        <result property="category"    column="category"     />
        <result property="readTime"    column="read_time"    />
        <result property="date"        column="date"         />
        <result property="published"   column="published"    />
        <result property="createTime"  column="create_time"  />
        <result property="updateTime"  column="update_time"  />
    </resultMap>
    
    <sql id="selectBlogVo">
        select id, title, excerpt, content, category, read_time, date, published, create_time, update_time 
        from sys_blog
    </sql>
    
    <select id="selectBlogList" parameterType="SysBlog" resultMap="SysBlogResult">
        <include refid="selectBlogVo"/>
        <where>
            <if test="title != null and title != ''">
                AND title like concat('%', #{title}, '%')
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="published != null">
                AND published = #{published}
            </if>
        </where>
        order by date desc
    </select>
    
    <select id="selectBlogById" parameterType="Long" resultMap="SysBlogResult">
        <include refid="selectBlogVo"/>
        where id = #{id}
    </select>
    
    <insert id="insertBlog" parameterType="SysBlog" useGeneratedKeys="true" keyProperty="id">
        insert into sys_blog (
            <if test="title != null and title != ''">title,</if>
            <if test="excerpt != null">excerpt,</if>
            <if test="content != null">content,</if>
            <if test="category != null">category,</if>
            <if test="readTime != null">read_time,</if>
            <if test="date != null">date,</if>
            <if test="published != null">published,</if>
            create_time
        )values(
            <if test="title != null and title != ''">#{title},</if>
            <if test="excerpt != null">#{excerpt},</if>
            <if test="content != null">#{content},</if>
            <if test="category != null">#{category},</if>
            <if test="readTime != null">#{readTime},</if>
            <if test="date != null">#{date},</if>
            <if test="published != null">#{published},</if>
            sysdate()
        )
    </insert>
    
    <update id="updateBlog" parameterType="SysBlog">
        update sys_blog 
        <set>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="excerpt != null">excerpt = #{excerpt},</if>
            <if test="content != null">content = #{content},</if>
            <if test="category != null">category = #{category},</if>
            <if test="readTime != null">read_time = #{readTime},</if>
            <if test="date != null">date = #{date},</if>
            <if test="published != null">published = #{published},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>
    
    <delete id="deleteBlogById" parameterType="Long">
        delete from sys_blog where id = #{id}
    </delete>
    
    <delete id="deleteBlogByIds" parameterType="Long">
        delete from sys_blog where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
</mapper>
